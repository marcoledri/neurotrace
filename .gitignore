# Dependencies
node_modules/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.Python

# Build output
dist/
dist-electron/
# electron-builder's intermediate dirs live under build/, but
# build/icon.{png,icns,ico} are the source app-icon files and MUST
# stay tracked. Can't use ``build/`` + ``!build/icon.png`` because
# git won't re-include paths inside an excluded directory — have to
# ignore the sub-paths directly.
build/pyi-dist/
build/pyi-work/
build/electron-builder/
backend-dist/
*.dmg
*.exe
*.AppImage

# Data files (too large for git)
sample_data/
*.dat
*.abf
*.h5
*.nwb
*.wcp

# Local environment
.env
.env.local
venv/
.venv/

# IDE / editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Electron user data / preferences
preferences.json

# Claude Code scratch
.claude/
.vite/
