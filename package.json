{
  "name": "neurotrace",
  "version": "0.2.1",
  "description": "Electrophysiology analysis software",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:python\" \"npm run dev:electron\"",
    "dev:electron": "vite",
    "dev:python": "cd backend && python main.py",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5",
    "uplot": "^1.6.31",
    "@tanstack/react-table": "^8.20.5",
    "@monaco-editor/react": "^4.6.0",
    "@xyflow/react": "^12.3.6",
    "msgpack-lite": "^0.1.26",
    "lucide-react": "^0.460.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.neurotrace.app",
    "productName": "NeuroTrace",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "backend-dist",
        "to": "backend"
      }
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
